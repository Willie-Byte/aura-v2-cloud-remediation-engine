# Kafka / Confluent Cloud settings
# Copy this file to backend/streaming/.env and fill in real values locally.
# Do not commit backend/streaming/.env.

USE_AZURE_KEY_VAULT=false

KAFKA_BROKER=your-bootstrap-server:9092
KAFKA_USERNAME=your-confluent-api-key
KAFKA_PASSWORD=your-confluent-api-secret

KAFKA_CLIENT_ID=aura-v2
KAFKA_SSL=true
KAFKA_SASL_MECHANISM=plain

# Logging
# Options: NOTHING, ERROR, WARN, INFO, DEBUG
KAFKA_LOG_LEVEL=WARN

# Suppresses repetitive local reconnect noise from KafkaJS while still allowing important startup logs.
KAFKA_SUPPRESS_CONNECTION_NOISE=true

# Connection and request timeouts
KAFKA_CONNECTION_TIMEOUT_MS=30000
KAFKA_AUTH_TIMEOUT_MS=30000
KAFKA_REQUEST_TIMEOUT_MS=60000

# General retry behavior
KAFKA_RETRIES=5
KAFKA_INITIAL_RETRY_TIME_MS=1000
KAFKA_MAX_RETRY_TIME_MS=30000
KAFKA_RETRY_FACTOR=0.2
KAFKA_RETRY_MULTIPLIER=2

# Consumer behavior
KAFKA_SESSION_TIMEOUT_MS=45000
KAFKA_HEARTBEAT_INTERVAL_MS=5000
KAFKA_REBALANCE_TIMEOUT_MS=90000
KAFKA_MAX_WAIT_TIME_MS=5000
KAFKA_CONSUMER_RETRIES=5
KAFKA_CONSUMER_INITIAL_RETRY_TIME_MS=1000
KAFKA_CONSUMER_MAX_RETRY_TIME_MS=30000
KAFKA_CONSUMER_RETRY_FACTOR=0.2
KAFKA_CONSUMER_RETRY_MULTIPLIER=2
KAFKA_PARTITIONS_CONSUMED_CONCURRENTLY=1

# Producer behavior
KAFKA_PRODUCER_MAX_IN_FLIGHT=1

# Topic names
KAFKA_TOPIC=threat-ingest
KAFKA_REMEDIATION_TOPIC=remediation-commands
KAFKA_DLQ_TOPIC=remediation-dlq
KAFKA_AUDIT_TOPIC=audit-log
KAFKA_RESULTS_TOPIC=execution-results
KAFKA_APPROVAL_TOPIC=approval-requests
KAFKA_APPROVAL_DECISIONS_TOPIC=approval-decisions
KAFKA_RAW_TELEMETRY_TOPIC=raw-telemetry
